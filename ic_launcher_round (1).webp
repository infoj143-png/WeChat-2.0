import com.infoj143.wechat20.viewmodel.CallViewModel

@Composable
fun CallScreen(
    viewModel: CallViewModel,
    peerId: String,
    isIncoming: Boolean,
    isVideo: Boolean,
    onCallEnded: () -> Unit
) {
    val callSession by viewModel.callSession.collectAsState()
    val isMuted by viewModel.isMuted.collectAsState()
    val isSpeakerOn by viewModel.isSpeakerOn.collectAsState()
    val isCameraOn by viewModel.isCameraOn.collectAsState()
    val callDuration by viewModel.callDuration.collectAsState()

    // When call ends, trigger callback
    LaunchedEffect(callSession) {
        if (callSession == null || callSession?.status == CallStatus.DISCONNECTED || callSession?.status == CallStatus.REJECTED) {
            onCallEnded()
        }
    }

    // Initialize call session if not existing
    LaunchedEffect(Unit) {
        val repManager = com.infoj143.wechat20.data.ServiceLocator.repository
        val activeUser = repManager.allUsers.value.find { it.id == peerId }
        activeUser?.let { u ->
            if (repManager.currentCall.value == null) {
                if (isIncoming) {
                    repManager.simulateIncomingCall(u, isVideo)
                } else {
                    viewModel.startOutgoingCall(u, isVideo)
                }
            }
        }
    }

    callSession?.let { session ->
        Box(
            modifier = Modifier
                .fillMaxSize()
                .background(MaterialTheme.colorScheme.background)
        ) {
            if (session.isVideo) {
                // --- VIDEO CALL UI SCREEN ---
                VideoCallLayout(
                    session = session,
                    isMuted = isMuted,
                    isCameraOn = isCameraOn,
                    durationText = viewModel.formatDuration(callDuration),
                    onToggleMute = { viewModel.toggleMute() },
                    onToggleCamera = { viewModel.toggleCamera() },
                    onEndCall = { viewModel.endCall() },
                    onAccept = { viewModel.acceptCall() },
                    onReject = { viewModel.rejectCall() }
                )
            } else {
                // --- VOICE CALL UI SCREEN ---
                VoiceCallLayout(
                    session = session,
                    isMuted = isMuted,
                    isSpeakerOn = isSpeakerOn,
                    durationText = viewModel.formatDuration(callDuration),
                    onToggleMute = { viewModel.toggleMute() },
                    onToggleSpeaker = { viewModel.toggleSpeaker() },
                    onEndCall = { viewModel.endCall() },
                    onAccept = { viewModel.acceptCall() },
                    onReject = { viewModel.rejectCall() }
                )
            }
        }
    }
}

@Composable
fun VoiceCallLayout(
    session: com.infoj143.wechat20.models.CallSession,
    isMuted: Boolean,
    isSpeakerOn: Boolean,
    durationText: String,
    onToggleMute: () -> Unit,
    onToggleSpeaker: () -> Unit,
    onEndCall: () -> Unit,
    onAccept: () -> Unit,
    onReject: () -> Unit
) {
    val context = LocalContext.current

    // Pulsing animations for Ringing/Dialing
    val isPulsing = session.status == CallStatus.RINGING || session.status == CallStatus.DIALING
    val pulseScale = rememberInfiniteTransition()
    val pulseVal by if (isPulsing) {
        pulseScale.animateFloat(
            initialValue = 1.0f,
            targetValue = 1.4f,
            animationSpec = infiniteRepeatable(
                animation = tween(1200, easing = FastOutSlowInEasing),
                repeatMode = RepeatMode.Reverse
            )
        )
    } else {
        remember { mutableStateOf(1.0f) }
    }

    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(24.dp),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.SpaceBetween
    ) {
        // Upper Caller Header
        Column(
            horizontalAlignment = Alignment.CenterHorizontally,
            modifier = Modifier.padding(top = 64.dp)
        ) {
            Text(
                text = when (session.status) {
                    CallStatus.DIALING -> "Dialing WeChat Voice..."
                    CallStatus.RINGING -> "Ringing..."
                    CallStatus.CONNECTED -> "Active Voice Call"
                    else -> "Disconnecting..."
                },
                color = MaterialTheme.colorScheme.onBackground.copy(alpha = 0.6f),
                fontSize = 14.sp,
                fontWeight = FontWeight.ExtraBold,
                letterSpacing = 1.sp
            )
            Spacer(modifier = Modifier.height(16.dp))
            Text(
                text = session.peer.name,
                color = MaterialTheme.colorScheme.onBackground,
                fontSize = 28.sp,
                fontWeight = FontWeight.ExtraBold,
                letterSpacing = (-1).sp
            )
            Spacer(modifier = Modifier.height(8.dp))
            if (session.status == CallStatus.CONNECTED) {
                Text(
                    text = durationText,
                    color = MaterialTheme.colorScheme.primary,
                    fontSize = 16.sp,
                    fontWeight = FontWeight.ExtraBold
                )
            }
        }

        // Concentric Pulsing Avatar
        Box(
            modifier = Modifier.size(240.dp),
            contentAlignment = Alignment.Center
        ) {
            if (isPulsing) {
                // Expanding glowing outline rings
                Box(
                    modifier = Modifier
                        .size(160.dp)
                        .scale(pulseVal)
                        .border(1.5.dp, MaterialTheme.colorScheme.primary.copy(alpha = 0.3f), CircleShape)
                )
                Box(
                    modifier = Modifier
                        .size(190.dp)
                        .scale(pulseVal * 1.15f)
                        .border(1.dp, MaterialTheme.colorScheme.primary.copy(alpha = 0.15f), CircleShape)
                )
            }

            Box(
                modifier = Modifier
                    .size(130.dp)
                    .clip(CircleShape)
                    .border(4.dp, MaterialTheme.colorScheme.primary, CircleShape)
            ) {
                AsyncImage(
                    model = ImageRequest.Builder(context)
                        .data(session.peer.profilePhotoUrl)
                        .crossfade(true)
                        .build(),
                    contentDescription = null,
                    modifier = Modifier.fillMaxSize(),
                    contentScale = ContentScale.Crop
                )
            }
        }

        // Bottom Dashboard Buttons
        Column(
            horizontalAlignment = Alignment.CenterHorizontally,
            modifier = Modifier.fillMaxWidth().padding(bottom = 32.dp)
        ) {
            if (session.isIncoming && session.status == CallStatus.RINGING) {
                // Incoming Call controls: Reject/Accept
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceEvenly,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    // Reject action
                    IconButton(
                        onClick = onReject,
                        modifier = Modifier
                            .size(72.dp)
                            .background(Color(0xFFEF4444), CircleShape)
                    ) {
                        Icon(Icons.Default.CallEnd, contentDescription = "Decline", tint = Color.White, modifier = Modifier.size(32.dp))
                    }

                    // Accept action
                    IconButton(
                        onClick = onAccept,
                        modifier = Modifier
                            .size(72.dp)
                            .background(Color(0xFF22C55E), CircleShape)
                    ) {
                        Icon(Icons.Default.Call, contentDescription = "Answer", tint = Color.White, modifier = Modifier.size(32.dp))
                    }
                }
            } else {
                // Dialing or Active Connected call controls
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceEvenly,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    // Mute control
                    IconButton(
                        onClick = onToggleMute,
                        modifier = Modifier
                            .size(56.dp)
                            .background(if (isMuted) MaterialTheme.colorScheme.primary else MaterialTheme.colorScheme.onBackground.copy(alpha = 0.1f), CircleShape)
                    ) {
                        Icon(
                            imageVector = if (isMuted) Icons.Default.MicOff else Icons.Default.Mic,
                            contentDescription = "Mute",
                            tint = if (isMuted) MaterialTheme.colorScheme.onPrimary else MaterialTheme.colorScheme.onBackground
                        )
                    }

                    // Hangup control
                    IconButton(
                        onClick = onEndCall,
                        modifier = Modifier
                            .size(68.dp)
                            .background(MaterialTheme.colorScheme.error, CircleShape)
                    ) {
                        Icon(Icons.Default.CallEnd, contentDescription = "End Call", tint = MaterialTheme.colorScheme.onError, modifier = Modifier.size(30.dp))
                    }

                    // Speaker control
                    IconButton(
                        onClick = onToggleSpeaker,
                        modifier = Modifier
                            .size(56.dp)
                            .background(if (isSpeakerOn) MaterialTheme.colorScheme.primary else MaterialTheme.colorScheme.onBackground.copy(alpha = 0.1f), CircleShape)
                    ) {
                        Icon(
                            imageVector = if (isSpeakerOn) Icons.Default.VolumeUp else Icons.Default.VolumeMute,
                            contentDescription = "Speaker",
                            tint = if (isSpeakerOn) MaterialTheme.colorScheme.onPrimary else MaterialTheme.colorScheme.onBackground
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun VideoCallLayout(
    session: com.infoj143.wechat20.models.CallSession,
    isMuted: Boolean,
    isCameraOn: Boolean,
    durationText: String,
    onToggleMute: () -> Unit,
    onToggleCamera: () -> Unit,
    onEndCall: () -> Unit,
    onAccept: () -> Unit,
    onReject: () -> Unit
) {
    val context = LocalContext.current

    // Video frame layout
    Box(modifier = Modifier.fillMaxSize()) {
        // 1. Peer Video Feed Container (covers full screen)
        Box(modifier = Modifier.fillMaxSize()) {
            AsyncImage(
                model = ImageRequest.Builder(context)
                    .data(session.peer.profilePhotoUrl)
                    .crossfade(true)
                    .build(),
                contentDescription = null,
                modifier = Modifier.fillMaxSize(),
                contentScale = ContentScale.Crop
            )
            // Overlay dim brush
            Box(
                modifier = Modifier
                    .fillMaxSize()
                    .background(
                        Brush.verticalGradient(
                            colors = listOf(
                                Color.Black.copy(alpha = 0.4f),
                                Color.Transparent,
                                Color.Black.copy(alpha = 0.7f)
                            )
                        )
                    )
            )
        }

        // 2. Active Call Metadata overlay (Top)
        Column(
            modifier = Modifier
                .fillMaxWidth()
                .statusBarsPadding()
                .padding(24.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Text(
                text = session.peer.name,
                color = Color.White,
                fontSize = 24.sp,
                fontWeight = FontWeight.ExtraBold,
                textAlign = TextAlign.Center
            )
            Spacer(modifier = Modifier.height(4.dp))
            Text(
                text = if (session.status == CallStatus.CONNECTED) durationText else "WeChat Video Call...",
                color = MaterialTheme.colorScheme.primary,
                fontSize = 14.sp,
                fontWeight = FontWeight.ExtraBold
            )
        }

        // 3. Floating local camera feed view card (top right)
        if (isCameraOn && session.status == CallStatus.CONNECTED) {
            Card(
                shape = RoundedCornerShape(12.dp),
                border = BorderStroke(1.5.dp, Color.White.copy(alpha = 0.3f)),
                colors = CardDefaults.cardColors(containerColor = Color.DarkGray),
                modifier = Modifier
                    .align(Alignment.TopEnd)
                    .padding(top = 100.dp, end = 16.dp)
                    .width(100.dp)
                    .height(150.dp)
            ) {
                Box(modifier = Modifier.fillMaxSize()) {
                    // Abstract dynamic colored gradient block representing your front camera feed
                    Box(
                        modifier = Modifier
                            .fillMaxSize()
                            .background(
                                Brush.linearGradient(
                                    colors = listOf(Color(0xFF0F9F90), Color(0xFF2563EB))
                                )
                            ),
                        contentAlignment = Alignment.Center
                    ) {
                        Text(
                            text = "Front Cam",
                            color = Color.White,
                            fontSize = 11.sp,
                            fontWeight = FontWeight.Bold
                        )
                    }
                }
            }
        }

        // 4. Floating control action deck (bottom)
        Column(
            modifier = Modifier
                .align(Alignment.BottomCenter)
                .navigationBarsPadding()
                .padding(bottom = 48.dp, start = 24.dp, end = 24.dp)
                .fillMaxWidth(),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            if (session.isIncoming && session.status == CallStatus.RINGING) {
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceEvenly,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    IconButton(
                        onClick = onReject,
                        modifier = Modifier
                            .size(70.dp)
                            .background(Color(0xFFEF4444), CircleShape)
                    ) {
                        Icon(Icons.Default.CallEnd, contentDescription = "Decline", tint = Color.White, modifier = Modifier.size(30.dp))
                    }
                    IconButton(
                        onClick = onAccept,
                        modifier = Modifier
                            .size(70.dp)
                            .background(Color(0xFF22C55E), CircleShape)
                    ) {
                        Icon(Icons.Default.Videocam, contentDescription = "Answer Video", tint = Color.White, modifier = Modifier.size(32.dp))
                    }
                }
            } else {
                Row(
                    modifier = Modifier
                        .clip(RoundedCornerShape(24.dp))
                        .background(Color.Black.copy(alpha = 0.6f))
                        .padding(horizontal = 24.dp, vertical = 12.dp),
                    horizontalArrangement = Arrangement.spacedBy(24.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    // Audio toggle
                    IconButton(onClick = onToggleMute) {
                        Icon(
                            imageVector = if (isMuted) Icons.Default.MicOff else Icons.Default.Mic,
                            contentDescription = "Mute",
                            tint = if (isMuted) Color.Red else Color.White
                        )
                    }

                    // Hangup Red call circle
                    IconButton(
                        onClick = onEndCall,
                        modifier = Modifier
                            .size(54.dp)
                            .background(Color(0xFFEF4444), CircleShape)
                    ) {
                        Icon(Icons.Default.CallEnd, contentDescription = "End", tint = Color.White)
                    }

                    // Camera On/Off Toggle
                    IconButton(onClick = onToggleCamera) {
                        Icon(
                            imageVector = if (isCameraOn) Icons.Default.Videocam else Icons.Default.VideocamOff,
                            contentDescription = "Camera Toggle",
                            tint = if (isCameraOn) Color.White else Color.Red
                        )
                    }
                }
            }
        }
    }
}
